# Backend Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Email Provider: 'sendgrid' or 'smtp'
EMAIL_PROVIDER=sendgrid

# ============================================
# SENDGRID CONFIGURATION (Recommended)
# ============================================
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=billing@leadflow.ai
SENDGRID_REPLY_TO=support@leadflow.ai

# ============================================
# SMTP CONFIGURATION (Alternative)
# ============================================
# For Gmail: use app-specific password (https://myaccount.google.com/apppasswords)
# For custom SMTP: use your provider's SMTP settings
SMTP_SERVICE=gmail
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_REPLY_TO=support@leadflow.ai

# ============================================
# DATABASE (Optional - for future use)
# ============================================
# DATABASE_URL=mongodb://localhost:27017/leadai
# FIREBASE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# FIREBASE_PROJECT_ID=your-project-id

# ============================================
# SECURITY (Optional - for future use)
# ============================================
# JWT_SECRET=your-jwt-secret-key-here
# API_RATE_LIMIT=100
# API_KEY=your-api-key-here

# ============================================
# LOGGING (Optional)
# ============================================
# LOG_LEVEL=info
# LOG_FILE=logs/app.log
